TO HILBERT :SIZE :LEVEL :DIR
  IF :LEVEL = 0 [STOP]
  LT :DIR
  HILBERT :SIZE :LEVEL - 1 (-:DIR)
  FD :SIZE
  RT :DIR
  HILBERT :SIZE :LEVEL - 1 :DIR
  FD :SIZE
  HILBERT :SIZE :LEVEL - 1 :DIR
  RT :DIR
  FD :SIZE
  HILBERT :SIZE :LEVEL - 1 (-:DIR)
  LT :DIR
END
CS HT
PU SETXY -150 -150 PD
SETPC 10
HILBERT 10 5 90
