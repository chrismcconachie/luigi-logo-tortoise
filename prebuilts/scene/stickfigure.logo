TO HEAD :R
  REPEAT 36 [FD :R * 0.1745 RT 10]
END
TO STICK
  ; Head
  PU SETXY 0 80 PD
  SETPENWIDTH 2
  HEAD 25
  ; Body
  PU SETXY 0 80 SETH 180 PD
  FD 100
  ; Arms
  PU SETXY 0 40 SETH 240 PD FD 50
  PU SETXY 0 40 SETH 120 PD FD 50
  ; Legs
  PU SETXY 0 -20 SETH 200 PD FD 80
  PU SETXY 0 -20 SETH 160 PD FD 80
END
CS HT
SETPC 0
STICK
